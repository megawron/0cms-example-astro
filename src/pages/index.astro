---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <h2>Welcome to 0CMS Astro</h2>
  <p>This is the homepage of the 0CMS Astro example — built with island architecture.</p>

  <h2>Featured Services</h2>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
    <div class="card">
      <img src="https://placehold.co/600x400" alt="Fast" style="width:100%;border-radius:4px"/>
      <h3>Fast</h3>
      <p>Astro ships zero JS by default — perfect for static sites.</p>
    </div>
    <div class="card">
      <img src="https://placehold.co/600x400" alt="Flexible" style="width:100%;border-radius:4px"/>
      <h3>Flexible</h3>
      <p>Use React, Vue, Svelte or plain HTML alongside Astro components.</p>
    </div>
  </div>

  <h2>FAQ</h2>
  <div class="accordion">
    <div class="accordion-item">
      <div class="accordion-header">What is Astro?</div>
      <div class="accordion-content">A modern static site builder with island architecture.</div>
    </div>
    <div class="accordion-item">
      <div class="accordion-header">Does it support React?</div>
      <div class="accordion-content">Yes, Astro supports React, Vue, Svelte and more as optional integrations.</div>
    </div>
  </div>
</Layout>
